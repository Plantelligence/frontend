{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/api/*",
      "/*.css",
      "/*.js",
      "/*.ico",
      "/*.png",
      "/*.jpg",
      "/*.jpeg",
      "/*.svg",
      "/*.webp",
      "/*.json"
    ]
  },
  "responseOverrides": {
    "401": {
      "rewrite": "/login",
      "statusCode": 302
    }
  }
}
